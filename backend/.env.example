# App
APP_NAME=Eco-Health Agentic Dietitian API
API_V1_STR=/api/v1
ENV=development
DEBUG=true

# LLM / Agent
GEMINI_API_KEY=
ADK_ENABLED=false
ADK_MODEL=gemini-2.0-flash

# AWS Cognito
